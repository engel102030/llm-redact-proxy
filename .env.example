# --- llm-redact-proxy config (copy to .env; .env is gitignored) ---
# Where the proxy listens. Point your LLM CLI's ANTHROPIC_BASE_URL here.
LISTEN_ADDR=127.0.0.1:8788
# The third-party / vendor endpoint the proxy forwards the REDACTED request to.
UPSTREAM_URL=https://api.anthropic.com
# Path to the gitignored file holding the secret VALUES to redact (one per line,
# or KEY=VALUE). This file is NEVER committed. See secrets.local.example.
SECRETS_FILE=./secrets.local
# Auth handling to the upstream: "passthrough" (forward the CLI's auth header as-is)
# or "replace" (swap in UPSTREAM_KEY below — use when the vendor needs its own key).
UPSTREAM_AUTH=passthrough
# UPSTREAM_KEY=   # only if UPSTREAM_AUTH=replace
# Fail-closed: if redaction/parse errors, BLOCK the request (never forward raw). Keep true.
FAIL_CLOSED=true
