# --- llm-redact-proxy config (copy to .env; .env is gitignored) ---
# Where the proxy listens. Point your LLM CLI's ANTHROPIC_BASE_URL here.
LISTEN_ADDR=127.0.0.1:8788
# The third-party / vendor endpoint the proxy forwards the REDACTED request to.
UPSTREAM_URL=https://api.anthropic.com
# Path to the GLOBAL secrets file holding the secret VALUES to redact (one per
# line, or KEY=VALUE). Typically an absolute path outside any repo, e.g.
# ~/.config/llm-redact-proxy/secrets.local. NEVER committed. See secrets.local.example.
SECRETS_FILE=./secrets.local
# Optional PER-PROJECT secrets file, checked in addition to the global one.
# Defaults to ./secrets.local relative to the working dir (the project). Both
# stores are redacted; secret_add can target global, project, or both.
# PROJECT_SECRETS_FILE=./secrets.local
# Auth handling to the upstream: "passthrough" (forward the CLI's auth header as-is)
# or "replace" (swap in UPSTREAM_KEY below — use when the vendor needs its own key).
UPSTREAM_AUTH=passthrough
# UPSTREAM_KEY=   # only if UPSTREAM_AUTH=replace
# Fail-closed: if redaction/parse errors, BLOCK the request (never forward raw). Keep true.
FAIL_CLOSED=true
# How aggressively to redact UNREGISTERED secrets (registered ones are always
# redacted). named-only = only your secrets.local list (zero false positives,
# good for internal/test work); balanced = named + recognizable shapes (JWT,
# PEM, API keys, cookies) but no entropy guessing; strict = everything (default,
# most secure).
REDACT_MODE=strict
# Hard minimum the runtime redact_mode tool cannot go below. Set to balanced or
# strict so a prompt-injected model cannot lower protection to exfiltrate.
REDACT_MODE_FLOOR=named-only
# Turn off individual rules by name (comma-separated), e.g. high-entropy-hex,jwt
# REDACT_DISABLE=
# Values or /regex/ patterns that are known-safe and must never be redacted
# (comma-separated). Patterns cannot contain commas. e.g. /^[0-9a-f]{64}$/
# REDACT_IGNORE=
